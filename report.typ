  columns: 5,
  align: center,
  stroke: 0.5pt,
  table.header([Шум], [Лучший hand-crafted], [F5 малый CNN], [F8 Мета], [F9 большой CNN]),
  [N1 Гаусс], [F2 = 12.97], [12.28], [12.76], [#text(weight: "bold")[15.75 (+2.8)]],
  [N2 Pink], [F6 = 9.57], [6.00], [7.66], [8.56],
  [N3 α-устойч.], [F4 = 17.95], [17.07], [18.33], [#text(weight: "bold")[22.75 (+4.8)]],
